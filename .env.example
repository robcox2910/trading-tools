# Trading Tools Environment Variables
# Copy this file to .env and fill in your credentials.
# Only configure the sections relevant to your use case — all values are optional.
#
# These values are referenced in src/trading_tools/config/settings.yaml.
# You can also override settings by creating src/trading_tools/config/settings.local.yaml.

# ── Revolut X API ──────────────────────────────────────────────────────────────
# Required for: trading-tools-fetch (with --source revolut-x), backtester (with --source revolut-x)
# See docs/GETTING_STARTED.md for Ed25519 key generation instructions.

REVOLUT_X_API_KEY=your_64_character_api_key_here
REVOLUT_X_PRIVATE_KEY_PATH=/path/to/your/private_key.pem
REVOLUT_X_BASE_URL=https://revx.revolut.com/api/1.0

# ── Polymarket CLOB API ───────────────────────────────────────────────────────
# Required for: trading, balance, orders, bots (trading-tools-polymarket)
# Not required for: market queries, tick collection, whale monitoring

POLYMARKET_PRIVATE_KEY=0x_your_polygon_wallet_private_key_here
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=
POLYMARKET_FUNDER_ADDRESS=your_proxy_wallet_address_here
POLYMARKET_CLOB_HOST=https://clob.polymarket.com
POLYMARKET_GAMMA_URL=https://gamma-api.polymarket.com

# ── Blockchain ─────────────────────────────────────────────────────────────────
POLYGON_RPC_URL=

# ── Database ───────────────────────────────────────────────────────────────────
# Set these to use PostgreSQL instead of the default SQLite.
# Format: postgresql+asyncpg://user:pass@host:5432/database
# If unset, commands fall back to local SQLite files.

TICK_DB_URL=sqlite+aiosqlite:///tick_data.db
WHALE_DB_URL=sqlite+aiosqlite:///whale_data.db
# Used by spread-capture bot to persist closed trade results (copy_results table).
# Falls back to WHALE_DB_URL if unset.
SPREAD_DB_URL=
DB_HOST=localhost
DB_PORT=5432
DB_NAME=trading_tools

# ── General ────────────────────────────────────────────────────────────────────

ENVIRONMENT=development
LOG_LEVEL=INFO
